# Ignore raw and processed data (except files tracked by Git LFS)
data/raw/
data/processed/
data/outputs/
data/resources/

# Do not ignore large binary files tracked by Git LFS
# (remove patterns for *.tif, *.csv, *.rds, *.shp, etc.)
# These are now managed by Git LFS.

# Ignore temporary and intermediate files
*.tmp
*.log

# Ignore Jupyter notebook checkpoints
.ipynb_checkpoints/

# Ignore shapefile auxiliary files not tracked by LFS
*.shx
*.dbf
*.prj
*.cpg
*.qpj

# Ignore system or editor-specific files
.DS_Store
.Rproj.user/
