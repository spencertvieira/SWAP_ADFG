# Do not ignore raw and processed data folders
# Allow LFS-tracked files in these folders
# (Removed: data/raw/, data/processed/, data/outputs/, data/resources/)

# Ignore temporary and intermediate files
*.tmp
*.log

# Ignore Jupyter notebook checkpoints
.ipynb_checkpoints/

# Ignore shapefile auxiliary files not tracked by LFS
*.shx
*.dbf
*.prj
*.cpg
*.qpj

# Ignore system or editor-specific files
.DS_Store
.Rproj.user/
